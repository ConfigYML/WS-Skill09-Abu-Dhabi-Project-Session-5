<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Session_5_Dennis_Hilfinger.MainPage"
             Title="Amenities Report">
    <ContentPage.Resources>
        <Style x:Key="HeadingStyle" TargetType="Label">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontFamily" Value="TexBold"/>
        </Style>
    </ContentPage.Resources>
    <ScrollView>
        <VerticalStackLayout 
            WidthRequest="800"
            HorizontalOptions="Center"
            Spacing="20">

            <HorizontalStackLayout
                Spacing="10">
                <RadioButton 
                    Content="Search by flight number and date"
                    GroupName="SearchType"
                    Value="FlightNumber"
                    IsChecked="True"
                    CheckedChanged="ChangeSearchType"/>
                <RadioButton 
                    Content="Search for time period"
                    GroupName="SearchType"
                    Value="TimePeriod"
                    IsChecked="False"
                    CheckedChanged="ChangeSearchType"/>
            </HorizontalStackLayout>
            
            <HorizontalStackLayout
                Spacing="10">
                <Label
                    Text="Flight number:"/>
                <Entry
                    x:Name="FlightNumberInput"
                    WidthRequest="150"/>
                <Label
                    Text="Flight date:"/>
                <DatePicker
                    x:Name="FlightDatePicker"
                    WidthRequest="150"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout
                Spacing="10">

                <Label
                    Text="From:"/>
                <DatePicker
                    x:Name="FromDatePicker"
                    WidthRequest="150"
                    IsEnabled="False"/>
                <Label
                    Text="To:"/>
                <DatePicker
                    x:Name="ToDatePicker"
                    WidthRequest="150"
                    IsEnabled="False"/>
            </HorizontalStackLayout>
            <Button
                Clicked="LoadReport"
                HorizontalOptions="Center"
                WidthRequest="150"
                HeightRequest="50"
                Text="Load report"/>
            <Grid
                x:Name="ReportGrid"
                RowDefinitions="*, *, *, *"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
